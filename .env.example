# Notion API Configuration
# ========================
# To get your Notion API key:
# 1. Go to https://www.notion.so/my-integrations
# 2. Click "New Integration"
# 3. Name your integration and select workspace
# 4. Copy the "Internal Integration Token" from the Secrets section
# 5. Share your Notion pages/databases with the integration (click Share > Add connections)

# General Integration Token (Internal Integration Token)
# Replace '<redacted>' with your actual token
NOTION_API_KEY=<notion_api_key>

# Dedicated Intermate Integration Token
#NOTION_API_KEY=<redacted>

# Optional: Notion API Version (default is 2022-06-28)
# NOTION_API_VERSION=2022-06-28

# Optional: Notion Database ID (if you're working with a specific database)
# NOTION_DATABASE_ID=your_database_id_here

# Optional: Notion Page ID (if you're working with a specific page)
# NOTION_PAGE_ID=your_page_id_here

# GitHub MCP Server Configuration
# ================================
# To get your GitHub Personal Access Token:
# 1. Go to https://github.com/settings/tokens
# 2. Click "Generate new token" → "Generate new token (classic)"
# 3. Give it a name and select scopes (at minimum: repo, read:org, read:user)
# 4. Copy the token and paste it below
# 5. Note: The token will only be shown once, so save it securely

# GitHub Personal Access Token (required for GitHub MCP Server)
# Replace '<redacted>' with your actual token
GITHUB_PERSONAL_ACCESS_TOKEN=<github_personal_access_token>

# Gemini MCP Server Configuration
# ===============================
# To get your Gemini API key:
# 1. Go to https://aistudio.google.com/app/apikey
# 2. Click "Create API Key" or "Get API Key"
# 3. Select or create a Google Cloud project
# 4. Copy the API key
# 5. Note: Keep your API key secure and never commit it to version control


# Gemini API Key (required for Gemini MCP Server)
# Replace '<redacted>' with your actual API key
GEMINI_API_KEY=<gemini_api_key>

# ==============================================================================
# Asana MCP Server Configuration
# ==============================================================================
# Get your Asana Personal Access Token from:
# https://app.asana.com/0/my-apps
# Create a new personal access token and paste it below
# ASANA_ACCESS_TOKEN=your_asana_access_token_here

# Optional: Asana Workspace ID (if you want to scope to a specific workspace)
# ASANA_WORKSPACE_ID=your_workspace_id_here

# ==============================================================================
# Apollo IO MCP Server Configuration
# ==============================================================================
# Get your Apollo IO API key from:
# https://app.apollo.io/#/settings/integrations/api
# Navigate to API Settings and generate or copy your API key
# Note: You need an Apollo IO account with API access
APOLLO_IO_API_KEY=<apollo_io_api_key>

# ==============================================================================
# MCP Integration - Additional API Keys
# ==============================================================================
# This section contains API keys for additional MCP servers and integrations
# that may be used in the project. Configure only the ones you need.

