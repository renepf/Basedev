# 1. Go to https://www.mongodb.com/cloud/atlas
# 2. Create a cluster and get your connection string
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname

# <redacted>
# PostgreSQL Configuration (if using PostgreSQL MCP servers)
# <redacted>
# Database connection string
# POSTGRES_CONNECTION_STRING=postgresql://username:password@host:port/database

# <redacted>
# Redis Configuration (if using Redis MCP servers)
# <redacted>
# Redis connection string
# REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=your_redis_password_here

# ==============================================================================
# MCP Server Environment Variables
# ==============================================================================
# These variables are used by MCP wrapper scripts and servers

# MCP Server Logging (optional)
# MCP_LOG_LEVEL=info  # Options: debug, info, warn, error
# MCP_LOG_FILE=/path/to/mcp.log

# MCP Server Timeout (optional, in seconds)
# MCP_TIMEOUT=30

# MCP Server Retry Configuration (optional)
# MCP_MAX_RETRIES=3
# MCP_RETRY_DELAY=1000  # milliseconds


# ==============================================================================
# DRIPIN PLATFORM - DATABASE CONFIGURATION
# ==============================================================================

# Central Content Database (CMS)
CENTRAL_DB_USER=<central_db_user>
CENTRAL_DB_PASSWORD=<central_db_password>
CENTRAL_DB_NAME=<central_db_name>
CENTRAL_DB_PORT=5435

# Shared Postgres (Development)
POSTGRES_USER=<postgres_user>
POSTGRES_PASSWORD=<postgres_password>
POSTGRES_DB=<postgres_db>
POSTGRES_PORT=5434

# ==============================================================================
# DRIPIN PLATFORM - INFRASTRUCTURE
# ==============================================================================

DRIPIN_DOMAIN=<dripin_domain>
ACME_EMAIL=<acme_email>
TIMEZONE=Europe/Berlin

# ==============================================================================
# DRIPIN PLATFORM - SECURITY
# ==============================================================================

JWT_SECRET=<jwt_secret>

# ==============================================================================
# DRIPIN PLATFORM - N8N WORKFLOW AUTOMATION
# ==============================================================================
# To get your n8n API key:
# 1. Start n8n service: docker compose up -d n8n
# 2. Go to https://n8n.dripin.ai (or http://localhost:5678 in dev)
# 3. Navigate to Settings → API
# 4. Create a new API key
# 5. Copy the key below

N8N_USER=<n8n_user>
N8N_PASSWORD=<n8n_password>
N8N_DB_NAME=<n8n_db_name>
N8N_HOST=<n8n_host>
# N8N_API_KEY=your_n8n_api_key_here  # Uncomment after creating in n8n dashboard
# N8N_BASE_URL=https://n8n.dripin.ai  # Or http://localhost:5678 for local dev

# ==============================================================================
# DRIPIN PLATFORM - RUST MAILER (SMTP/Email Service)
# ==============================================================================
# For Gmail, you need an App Password (not your regular password):
# 1. Google Account → Security → 2-Step Verification
# 2. App Passwords → Generate
# 3. Copy the generated password below

SMTP_HOST=<smtp_host>
SMTP_PORT=587
SMTP_USER=<smtp_user>
SMTP_PASSWORD=<smtp_password>
SMTP_FROM=<smtp_from>
RUST_MAILER_DB_NAME=<rust_mailer_db_name>

# ==============================================================================
# DRIPIN PLATFORM - LANGGRAPH MAIL (AI Email Automation)
# ==============================================================================

LANGGRAPH_MAIL_DB_NAME=<langgraph_mail_db_name>
# OPENAI_API_KEY=<redacted>
# LANGGRAPH_API_KEY=change_me
RUST_MAILER_URL=<rust_mailer_url>
N8N_WEBHOOK_URL=<n8n_webhook_url>

# ==============================================================================
# DRIPIN PLATFORM - GMAIL API
# ==============================================================================
# Setup:
# 1. Google Cloud Console → APIs & Services → Enable Gmail API
# 2. Credentials → OAuth 2.0 Client ID erstellen
# 3. Redirect URI: https://langgraph-mail.dripin.ai/oauth/callback
# 4. Scopes: https://www.googleapis.com/auth/gmail.readonly, https://www.googleapis.com/auth/gmail.send
# 5. Refresh Token generieren (OAuth Flow)

# GMAIL_CLIENT_ID=change_me_google_oauth_client_id
# GMAIL_CLIENT_SECRET=change_me_google_oauth_client_secret
# GMAIL_REFRESH_TOKEN=change_me_google_oauth_refresh_token

# ==============================================================================
# DRIPIN PLATFORM - GOOGLE DRIVE API
# ==============================================================================
# Setup:
# 1. Google Cloud Console → APIs & Services → Enable Drive API
# 2. Credentials → OAuth 2.0 Client ID erstellen
# 3. Redirect URI: https://langgraph-mail.dripin.ai/oauth/callback
# 4. Scopes: https://www.googleapis.com/auth/drive.readonly, https://www.googleapis.com/auth/drive.file
# 5. Refresh Token generieren (OAuth Flow)

# GOOGLE_DRIVE_CLIENT_ID=change_me_google_oauth_client_id
# GOOGLE_DRIVE_CLIENT_SECRET=change_me_google_oauth_client_secret
# GOOGLE_DRIVE_REFRESH_TOKEN=change_me_google_oauth_refresh_token

# ==============================================================================
# DRIPIN PLATFORM - CLOUD STORAGE (Optional)
# ==============================================================================

# AWS S3
# AWS_ACCESS_KEY_ID=change_me
# AWS_SECRET_ACCESS_KEY=change_me
# AWS_REGION=eu-central-1
# AWS_S3_BUCKET=dripin-storage

# Google Cloud Storage
# GCS_PROJECT_ID=change_me
# GCS_KEY_FILE=/path/to/service-account.json
# GCS_BUCKET=dripin-storage

# ==============================================================================
# DRIPIN PLATFORM - REDIS
# ==============================================================================

REDIS_PASSWORD=<redis_password>
REDIS_PORT=6379

# ==============================================================================
# DRIPIN PLATFORM - NODE ENVIRONMENT
# ==============================================================================

NODE_ENV=development
RUST_LOG=info

# ==============================================================================
# AI HANDLER BACKEND - CORE CONFIGURATION
# ==============================================================================
# These variables are required for the AI Handler backend (Rust) to run

# ==============================================================================
# Database Configuration (REQUIRED)
# ==============================================================================
DATABASE_URL=<database_url>
POSTGRES_USER=<postgres_user>
POSTGRES_PASSWORD=<postgres_password>
POSTGRES_DB=<postgres_db>

# ==============================================================================
# Redis Configuration (REQUIRED)
# ==============================================================================
REDIS_URL=<redis_url>

# ==============================================================================
# JWT Configuration (REQUIRED)
# ==============================================================================
# Generate a secure secret: openssl rand -hex 32
JWT_SECRET=<jwt_secret>
JWT_EXPIRES_IN=7d

# ==============================================================================
# Encryption Key (REQUIRED)
# ==============================================================================
# Used to encrypt API keys and sensitive data
# Must be 32 bytes (64 hex characters)
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=<encryption_key>

# ==============================================================================
# Application Configuration
# ==============================================================================
PORT=3000
API_BASE_URL=<api_base_url>
FRONTEND_URL=<frontend_url>

# ==============================================================================
# Logging
# ==============================================================================
LOG_LEVEL=info

# ==============================================================================
# OAuth Configuration - Google (Optional)
# ==============================================================================
# Get credentials from: https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=<redacted>
GOOGLE_REDIRECT_URI=<google_redirect_uri>

# ==============================================================================
# OAuth Configuration - Apple (Optional)
# ==============================================================================
# Get credentials from: https://developer.apple.com/account/resources/identifiers/list
# APPLE_CLIENT_ID=your-apple-client-id
# APPLE_TEAM_ID=your-apple-team-id
# APPLE_KEY_ID=your-apple-key-id
# APPLE_PRIVATE_KEY=your-apple-private-key
APPLE_REDIRECT_URI=<apple_redirect_uri>

# ==============================================================================
# OAuth Configuration - X (Twitter) (Optional)
# ==============================================================================
# Get credentials from: https://developer.twitter.com/en/portal/dashboard
# X_CLIENT_ID=your-x-client-id
# X_CLIENT_SECRET=your-x-client-secret
X_REDIRECT_URI=<x_redirect_uri>

# ==============================================================================
# Stripe Configuration (Optional - for payments)
# ==============================================================================
# Get your Stripe API keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=<stripe_secret_key>
# STRIPE_TRIAL_PRICE_ID=price_trial_week
# JSON string with provider price IDs: {"openai":"price_xxx","claude":"price_yyy","gemini":"price_zzz"}
STRIPE_PROVIDER_PRICE_IDS=<stripe_provider_price_ids>

# ==============================================================================
# Google oAuth
# ==============================================================================

GOOGLE_CLIENT_ID=<google_client_id>
GOOGLE_CLIENT_SECRET=<google_client_secret>
GOOGLE_REDIRECT_URI=<google_redirect_uri>

# ==============================================================================
# Email Service Configuration (Optional)
# ==============================================================================
# Choose one provider: "smtp", "sendgrid", "ses", "mailgun", "resend"
# EMAIL_SERVICE_PROVIDER=smtp

# SMTP Configuration (if EMAIL_SERVICE_PROVIDER=smtp)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-smtp-password
# SMTP_FROM_EMAIL=noreply@example.com
# SMTP_FROM_NAME=AI Handler

# SendGrid Configuration (if EMAIL_SERVICE_PROVIDER=sendgrid)
# Get API key from: https://app.sendgrid.com/settings/api_keys
# SENDGRID_API_KEY=<redacted>

# AWS SES Configuration (if EMAIL_SERVICE_PROVIDER=ses)
# AWS_SES_REGION=us-east-1
# AWS_SES_ACCESS_KEY_ID=your-aws-access-key-id
# AWS_SES_SECRET_ACCESS_KEY=<redacted>

# Mailgun Configuration (if EMAIL_SERVICE_PROVIDER=mailgun)
# Get credentials from: https://app.mailgun.com/app/sending/domains
# MAILGUN_API_KEY=your-mailgun-api-key
# MAILGUN_DOMAIN=your-mailgun-domain.com

# Resend Configuration (if EMAIL_SERVICE_PROVIDER=resend)
# Get API key from: https://resend.com/api-keys
# RESEND_API_KEY=<redacted>

OPENROUTE1R_API_KEY=<openroute1r_api_key>
OPENAI_API_KEY=<openai_api_key>

